# ── CoinGPT Bot — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to version control!

# Required — get yours from @BotFather on Telegram
BOT_TOKEN=

# Optional — controls log verbosity (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Optional — CryptoPanic API key for live news
# https://cryptopanic.com/developers/api/
NEWS_API_KEY=

# Optional — OpenAI API key for real AI responses
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
